# Local Development Environment Variables
# Copy this file to .env.local and adjust values as needed

# MySQL Configuration
MYSQL_ROOT_PASSWORD=techwikiplus
MYSQL_DATABASE=techwikiplus
MYSQL_USER=techwikiplus
MYSQL_PASSWORD=techwikiplus
MYSQL_PORT=13306

# Redis Configuration
REDIS_PASSWORD=techwikiplus
REDIS_PORT=16379

# JWT Configuration (Development)
JWT_SECRET=techwikiplus-jwt-secret-key-for-authentication-2024
JWT_ACCESS_TOKEN_EXPIRATION=3600000      # 1 hour
JWT_REFRESH_TOKEN_EXPIRATION=604800000   # 7 days

# Mail Configuration (Console output for development)
SPRING_MAIL_TYPE=console
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
MAIL_USERNAME=noreply@techwikiplus.com
MAIL_PASSWORD=techwikiplus

# Service Configuration
USER_SERVICE_PORT=9000

# Logging Levels (Debug for development)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_TECHWIKIPLUS=DEBUG
LOGGING_LEVEL_SPRING_WEB=DEBUG
LOGGING_LEVEL_SPRING_SECURITY=DEBUG
LOGGING_LEVEL_HIBERNATE_SQL=DEBUG

# CORS Configuration (Allow all for development)
CORS_ALLOWED_ORIGINS=*

# JPA Configuration
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Actuator Configuration
MANAGEMENT_HEALTH_MAIL_ENABLED=false