# 프로덕션 환경 설정 예시
# 실제 사용 시 .env로 복사하여 사용

# User Service 이미지 설정 (ECR 레지스트리)
# CI/CD에서 자동으로 업데이트됨 - 초기값은 .github/workflows/ci-cd.yml의 ECR_REPOSITORY_NAME 참고
USER_SERVICE_IMAGE=127994096408.dkr.ecr.ap-northeast-2.amazonaws.com/techwikiplus/user-service:latest

# 데이터베이스 설정 (보안을 위해 강력한 비밀번호 사용)
MYSQL_ROOT_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
MYSQL_DATABASE=techwikiplus
MYSQL_USER=techwikiplus
MYSQL_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
MYSQL_PORT=3306

# Redis 설정 (보안을 위해 강력한 비밀번호 사용)
REDIS_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
REDIS_PORT=6379

# JWT 설정 (프로덕션용 - 반드시 변경 필요!)
JWT_SECRET=CHANGE_THIS_TO_64_CHARACTER_SECURE_RANDOM_STRING_FOR_PRODUCTION
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# 메일 설정 (실제 SMTP 서버 정보)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# 서비스 포트
USER_SERVICE_PORT=9000

# JPA 설정 (프로덕션에서는 validate 권장)
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# 로깅 레벨 (프로덕션용)
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_TECHWIKIPLUS=INFO
LOGGING_LEVEL_SPRING_WEB=WARN
LOGGING_LEVEL_SPRING_SECURITY=WARN
LOGGING_LEVEL_HIBERNATE_SQL=WARN

# JVM 옵션 (프로덕션 최적화)
JAVA_OPTS=-Xms1g -Xmx2g -XX:+UseG1GC -XX:MaxGCPauseMillis=200
